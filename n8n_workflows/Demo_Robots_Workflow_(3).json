    {
      "parameters": {
        "jsCode": "// Command Center Result: enrich LLM output with decision context\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = { ...item.json };\n  const agents = data.output?.assign_agents || [];\n\n  // Determine situation from agent assignments\n  const h1Assignment = agents.find(a => a.agent === 'h1');\n  const h1_2Assignment = agents.find(a => a.agent === 'h1_2');\n  const manipulatorAssignment = agents.find(a => a.agent === 'manipulator');\n\n  // If H1 is stopping (stay) and H1_2 exists, ensure H1_2 continues patrol\n  if (h1Assignment && h1Assignment.command === 'stay') {\n    if (!h1_2Assignment) {\n      agents.push({ agent: 'h1_2', command: 'continue_patrol' });\n    }\n    if (manipulatorAssignment && manipulatorAssignment.command === 'pick_and_place') {\n      data.command_center_summary = 'Both robots spotted the object. ' +\n        'H1 is closest \u2014 stopping near the object for pickup. ' +\n        'H1_2 continues patrolling ahead. ' +\n        'Manipulator will perform pick and place.';\n    } else {\n      data.command_center_summary = 'H1 is holding position. H1_2 continues patrol.';\n    }\n  } else if (h1_2Assignment && !h1Assignment) {\n    data.command_center_summary = 'H1_2 spotted the object but H1 is handling it. H1_2 continues patrol.';\n  } else {\n    data.command_center_summary = 'Command Center evaluated the situation and assigned agents.';\n  }\n\n  // Build decision string from actual assignments\n  data.command_center_decision = agents.map(a => a.agent + ' \u2192 ' + a.command).join(' | ');\n\n  // Preserve the output structure for Split Out\n  data.output = data.output || {};\n  data.output.assign_agents = agents;\n\n  results.push({ json: data });\n}\n\nreturn results;"
      },
